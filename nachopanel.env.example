NODE_ENV=production
NACHO_VERSION=3.0.1
NACHO_PROXY_MODE=caddy
NACHO_APP_HOST=127.0.0.1
HOSTNAME=127.0.0.1
PORT=3000
NACHO_INSTALLER_HOST=127.0.0.1
INSTALLER_PORT=8091
NACHO_INSTALLER_PUBLIC_PORT=8090
INSTALLER_GATEWAY_DISABLED=0
NACHO_PUBLIC_URL=https://panel.example.com
NACHO_INSTALLER_PUBLIC_URL=https://panel.example.com:8090
NACHO_AGENT_AUTH_MODE=required
NACHO_DATABASE_MODE=managed
NACHO_DB_USER=nachopanel
NACHO_DB_NAME=nachopanel
NACHO_DB_HOST=
NACHO_DB_PORT=5432
NACHO_DB_SSLMODE=disable
# Generated automatically and stored only in the root-owned runtime file.
DATABASE_URL=postgresql://nachopanel:generated-password@127.0.0.1:5432/nachopanel
NACHO_DATA_DIR=/var/lib/nachopanel
NACHO_ARTIFACT_DIR=/var/lib/nachopanel/artifacts
# Optional S3-compatible artifact storage (takes precedence over NACHO_ARTIFACT_DIR)
# NACHO_S3_BUCKET=nachopanel
# NACHO_S3_REGION=us-east-1
# NACHO_S3_ENDPOINT=https://s3.example.com
# NACHO_S3_PATH_STYLE=1
# Legacy environment management keys are optional. Prefer database-backed keys
# created by: node server/admin-cli.mjs key create --name recovery --scope admin
